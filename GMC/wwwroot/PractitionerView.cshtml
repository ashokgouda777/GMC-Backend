<!DOCTYPE html>
<html>
<head>
    <title>Goa Medical Council - Practitioner Details</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            margin: 0;
        }

        .container {
            width: 700px;
            margin: 40px auto;
            background: #fff;
            border: 1px solid #ddd;
            padding: 30px;
            border-radius: 8px;
        }

        .header {
            text-align: center;
        }

        .header img {
            width: 80px;
        }

        .title {
            font-size: 20px;
            font-weight: bold;
            margin-top: 10px;
        }

        .subtitle {
            font-size: 13px;
            color: #666;
        }

        .section-title {
            text-align: center;
            margin: 20px 0;
            font-weight: bold;
            color: #2c3e50;
        }

        .details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            row-gap: 15px;
        }

        .label {
            color: #2c3e50;
            font-weight: 500;
        }

        .value {
            color: #000;
        }

        hr {
            margin: 15px 0;
        }
    </style>
</head>

<body>

    <div class="container">

        <!-- Header -->
        <div class="header">
            <img src="logo.png" alt="Goa Logo">
            <div class="title">Goa Medical Council</div>
            <div class="subtitle">Panaji, Goa - 403001</div>
        </div>

        <div class="section-title">REGISTER</div>
        <hr>

        <!-- Details -->
        <div class="details">
            <div class="label">Register No:</div>
            <div class="value">12345</div>

            <div class="label">Name in Full:</div>
            <div class="value">Dr. John Doe</div>

            <div class="label">Sex:</div>
            <div class="value">Male</div>

            <div class="label">Father's Name:</div>
            <div class="value">ABC Doe</div>

            <div class="label">Nationality:</div>
            <div class="value">Indian</div>

            <div class="label">Date of Birth:</div>
            <div class="value">01/01/1995</div>

            <div class="label">Blood Group:</div>
            <div class="value">O +ve</div>

            <div class="label">Birth Place:</div>
            <div class="value">Goa</div>

            <div class="label">Mobile Number:</div>
            <div class="value">9876543210</div>

            <div class="label">Email Id:</div>
            <div class="value">doctor@gmail.com</div>
        </div>

    </div>

</body>
</html>